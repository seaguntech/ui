{
  "name": "@seaguntech/vitest-config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./index.js",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./index.js"
    },
    "./react": {
      "types": "./react.ts",
      "default": "./react.js"
    },
    "./node": {
      "types": "./node.ts",
      "default": "./node.js"
    }
  },
  "dependencies": {
    "vitest": "catalog:testing",
    "@vitest/coverage-v8": "catalog:testing",
    "@vitest/ui": "catalog:testing",
    "jsdom": "catalog:testing",
    "vite": "catalog:vite-ecosystem",
    "@vitejs/plugin-react": "catalog:vite-ecosystem",
    "vite-tsconfig-paths": "catalog:vite-ecosystem"
  }
}

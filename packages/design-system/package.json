{
  "name": "@seaguntech/design-system",
  "private": false,
  "version": "0.1.0",
  "author": "Seaguntech",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seaguntech/ui.git",
    "directory": "packages/design-system"
  },
  "homepage": "https://github.com/seaguntech/ui/tree/main/packages/design-system",
  "bugs": {
    "url": "https://github.com/seaguntech/ui/issues"
  },
  "keywords": [
    "seaguntech",
    "design-system",
    "tailwindcss",
    "tokens",
    "css-variables",
    "theme"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "Tailwind CSS v4 design tokens for Seaguntech UI",
  "exports": {
    ".": "./globals.css",
    "./globals": "./globals.css",
    "./design-tokens": "./design-tokens.css",
    "./theme-light": "./theme-light.css",
    "./theme-dark": "./theme-dark.css",
    "./postcss-config": "./postcss-config.js"
  },
  "files": [
    "*.css",
    "postcss-config.js"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "echo 'design-system ready'",
    "lint": "echo 'no lint yet'",
    "lint:fix": "echo 'no lint yet'",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "check-types": "echo 'no types'",
    "test": "echo 'no tests'",
    "test:watch": "echo 'no tests'",
    "test:coverage": "echo 'no tests'",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@tailwindcss/postcss": "catalog:web-ui",
    "postcss": "catalog:web-ui",
    "tailwindcss": "catalog:web-ui"
  },
  "devDependencies": {
    "@seaguntech/eslint-config": "workspace:*",
    "@seaguntech/prettier-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@seaguntech/prettier-config/base"
}

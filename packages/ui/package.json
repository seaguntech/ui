{
  "name": "@seaguntech/ui",
  "version": "0.1.1",
  "description": "Shared React UI component library for Seaguntech.",
  "author": "Seaguntech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seaguntech/ui.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/seaguntech/ui/tree/main/packages/ui",
  "bugs": {
    "url": "https://github.com/seaguntech/ui/issues"
  },
  "keywords": [
    "seaguntech",
    "react",
    "ui",
    "component-library",
    "tailwindcss",
    "radix-ui",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./src/styles/globals.css"
  },
  "files": [
    "dist",
    "src/styles/globals.css"
  ],
  "sideEffects": [
    "src/styles/globals.css"
  ],
  "scripts": {
    "dev": "tsup",
    "build": "tsup",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --max-warnings 0 --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "check-types": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "catalog:radix-ui",
    "@radix-ui/react-dropdown-menu": "catalog:radix-ui",
    "@radix-ui/react-label": "catalog:radix-ui",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "catalog:radix-ui",
    "@radix-ui/react-slot": "catalog:radix-ui",
    "@radix-ui/react-tabs": "catalog:radix-ui",
    "@seaguntech/design-system": "workspace:*",
    "class-variance-authority": "catalog:web-ui",
    "clsx": "catalog:web-ui",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "catalog:web-ui",
    "tailwind-merge": "catalog:web-ui"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@seaguntech/eslint-config": "workspace:*",
    "@seaguntech/prettier-config": "workspace:*",
    "@seaguntech/typescript-config": "workspace:*",
    "@seaguntech/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitest/coverage-v8": "catalog:testing",
    "@vitest/ui": "catalog:testing",
    "eslint": "catalog:",
    "postcss": "catalog:web-ui",
    "prettier": "catalog:",
    "tailwindcss": "catalog:web-ui",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:testing"
  }
}

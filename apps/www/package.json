{
  "name": "@seaguntech/www",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack --port 4200",
    "build": "pnpm build:registry && next build",
    "start": "next start",
    "build:registry": "tsx scripts/build-registry.ts && pnpm validate:registry",
    "validate:registry": "tsx scripts/validate-registries.ts",
    "lint": "eslint . --ignore-pattern .next --ignore-pattern playwright-report --ignore-pattern test-results",
    "lint:fix": "eslint . --fix --ignore-pattern .next --ignore-pattern playwright-report --ignore-pattern test-results",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "clean": "rm -rf .next coverage test-results playwright-report"
  },
  "dependencies": {
    "@seaguntech/design-system": "workspace:*",
    "@seaguntech/ui": "workspace:*",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "next": "^16.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn": "^3.4.2",
    "shiki": "^4.0.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.20.4",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
